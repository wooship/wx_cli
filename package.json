    "readline": "^1.3.0",
    "winston": "^3.18.3",
    "ws": "^8.0.0",
    "yaml": "^2.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/jest": "^29.0.0",
